{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Information about prospective clients and lead form submissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "source": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Submissions to lead generation and contact forms across the agency"
    }
  }
}
