rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'austinegreat9@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Lead Validation Helper
    function isValidLead(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.keys().size() <= 15 &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 256)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 100)) &&
             (!('company' in data) || (data.company is string && data.company.size() <= 256)) &&
             (!('industry' in data) || (data.industry is string && data.industry.size() <= 256)) &&
             (!('challenge' in data) || (data.challenge is string && data.challenge.size() <= 1000)) &&
             (!('question' in data) || (data.question is string && data.question.size() <= 1000)) &&
             (!('source' in data) || (data.source is string && data.source.size() <= 512)) &&
             (!('timestamp' in data) || (data.timestamp is string && data.timestamp.size() <= 100));
    }

    // Leads collection rules
    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(request.resource.data);
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow update: if isAdmin() && isValidLead(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // Admins collection rules (optional bootstrapping)
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
